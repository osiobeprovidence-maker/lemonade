# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_CONVEX_URL: The frontend Convex URL used by the Vite app.
# Set this to your Convex deployment URL.
VITE_CONVEX_URL="https://kindred-perch-89.eu-west-1.convex.cloud"

# CONVEX_URL: Optional server-side Convex URL for scripts and tooling.
CONVEX_URL="https://kindred-perch-89.eu-west-1.convex.cloud/"

# CONVEX_SITE_URL: The action URL for Convex server-side functions.
CONVEX_SITE_URL="https://kindred-perch-89.eu-west-1.convex.site/"

# Firebase Configuration (for Authentication)
VITE_FIREBASE_PROJECT_ID="gen-lang-client-0261238438"
VITE_FIREBASE_APP_ID="1:523804729634:web:f8e6ef8052b095c9fb457b"
VITE_FIREBASE_API_KEY="AIzaSyA2MSr0wOLWk5vZo_aPRjOs9TrqbHzyi1k"
VITE_FIREBASE_AUTH_DOMAIN="gen-lang-client-0261238438.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="gen-lang-client-0261238438.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="523804729634"
VITE_FIREBASE_DATABASE_ID="ai-studio-5d9b9817-b5c5-463d-938f-8a6508f42d09"

# Firebase Admin SDK credentials for server-side scripts like backfillFirebaseUsers.ts
FIREBASE_SERVICE_ACCOUNT_PATH="./secrets/firebase-service-account.json"
